# Dependency and build output
node_modules/
**/node_modules/
dist/
**/dist/
deploy_bundle/
.turbo/
.verify-artifacts/
*.log

# NIST demo trajectories are large glimbin blobs — hosted on GCS in prod
# (resolved via VITE_NIST_BASE_URL), symlinked locally for dev. Never commit.
apps/web/public/nist/demos/

# Local environment-pack candidate runs are promoted explicitly before commit.
tools/lupi-environment-candidates/
tools/lupi-motion-cache/
tools/lupi-panorama-runs.jsonl

# Local Firebase/GCP and Vite runtime config. Keep examples tracked, never
# commit real Vite mode files such as apps/web/.env.production.
.env
.env.*
!.env.example
apps/*/.env
apps/*/.env.*
!apps/*/.env.example

# Generated MD trajectories (regenerate via tools/sims/make_phase_trajectories.py)
tools/sims/output/
