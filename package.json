{
  "name": "lupi-live",
  "version": "0.3.0",
  "private": true,
  "description": "WebGPU-powered LAMMPS molecular dynamics visualization platform",
  "license": "AGPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "https://github.com/alexwelcing/Lupi.git"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "start": "node tools/serve-web.mjs",
    "dev": "turbo run dev",
    "build": "turbo run build",
    "build:wasm": "cd packages/parsers/wasm && wasm-pack build --target web --out-dir ../pkg",
    "nist:build": "npx -y tsx scripts/build-nist-catalog.ts",
    "test": "turbo run test --concurrency=1",
    "test:rust": "cd packages/parsers/wasm && cargo test",
    "audit:nomenclature": "node tools/audit-gallery-nomenclature.mjs",
    "backup:gallery": "node tools/audit-gallery-nomenclature.mjs --write --backup",
    "doctor": "npx -y tsx tools/lupi-doctor.mjs",
    "bake:glimbin": "npx -y tsx tools/bake-glimbin.mjs",
    "sims:phase-change": "python3 tools/sims/make_phase_trajectories.py all --size demo",
    "atomize:media": "node tools/atomize-media.mjs",
    "generate:sphere-grid": "node tools/generate-sphere-grid-gallery.mjs",
    "generate:sphere-grid:assets": "node tools/generate-sphere-grid-gallery.mjs --no-snapshot",
    "analytics:report": "node tools/analytics-report.mjs",
    "lint": "turbo run lint",
    "clean": "turbo run clean"
  },
  "devDependencies": {
    "@gltf-transform/core": "^4.3.0",
    "@gltf-transform/extensions": "^4.3.0",
    "@react-three/test-renderer": "^9.1.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@webgpu/types": "^0.1.69",
    "canvas": "^3.2.3",
    "jsdom": "^29.1.1",
    "jsqr": "^1.4.0",
    "playwright": "^1.59.1",
    "qrcode": "^1.5.4",
    "three": "^0.184.0",
    "turbo": "^2.3.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.5"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@types/node": "^22.0.0",
    "leva": "^0.10.1",
    "serve": "^14.2.6"
  },
  "pnpm": {
    "packageExtensions": {
      "@iwer/devui": {
        "dependencies": {
          "zustand": "^4.5.5"
        }
      }
    }
  }
}
